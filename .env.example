# AI Employee Environment Variables
# Copy this file to .env and fill in your values

# DashScope API Key (required for Qwen Agent)
# Get your API key from: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your_api_key_here

# Qwen Model Selection
# Options: qwen-turbo, qwen-plus, qwen-max, qwen-max-longcontext
QWEN_MODEL=qwen-plus

# AI Employee Vault Path
AI_EMPLOYEE_VAULT=./AI_Employee_Vault

# Debug mode (set to 'true' for verbose logging)
DEBUG=false

# Dry run mode (set to 'true' to simulate without executing)
DRY_RUN=false

# Check interval for watchers (in seconds)
WATCHER_INTERVAL=30

# Maximum iterations for persistence loop
MAX_ITERATIONS=10
