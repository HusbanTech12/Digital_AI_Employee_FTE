{
  "permissions": {
    "allow": [
      "Bash(mkdir *)",
      "Bash(python *)",
      "Bash(pip install *)",
      "Bash(qwen *)",
      "Bash(dir *)",
      "Bash(type *)",
      "Bash(copy *)",
      "Bash(move *)",
      "Bash(del *)",
      "Bash(echo *)",
      "ReadFile(*)",
      "WriteFile(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "LS(*)",
      "Agent(*)",
      "Bash(ollama *)",
      "Bash(setx *)",
      "Bash(\"c:\\users\\fattani computers\\appdata\\local\\programs\\ollama\\ollama.exe\" *)",
      "Bash(powershell *)",
      "Bash(.\\configure-ollama.bat)",
      "Bash(pip show *)",
      "Bash(.\\test-ollama.bat)",
      "Bash(start *)",
      "Bash(.\\quick-start-ollama.bat)",
      "Bash(.\\test-full-system.bat)",
      "Bash(taskkill *)",
      "WebSearch",
      "WebFetch(qwenlm.github.io)",
      "WebFetch(docs.roocode.com)"
    ]
  },
  "model": {
    "name": "qwen-plus",
    "provider": "dashscope"
  },
  "features": {
    "enable_mcp": true,
    "enable_skills": true,
    "enable_file_watching": true
  },
  "vault": {
    "path": "./AI_Employee_Vault",
    "folders": {
      "inbox": "Inbox",
      "needs_action": "Needs_Action",
      "plans": "Plans",
      "done": "Done",
      "pending_approval": "Pending_Approval",
      "approved": "Approved",
      "rejected": "Rejected",
      "logs": "Logs"
    }
  },
  "$version": 3
}